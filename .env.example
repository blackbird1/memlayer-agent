# --- Required ---

# ProcIQ MCP bearer token (https://prociq.ai — sign up, create org, generate token)
MEMLAYER_MCP_BEARER_TOKEN=your_memlayer_mcp_bearer_token

# Redis address (Docker Compose sets this automatically; override for local dev)
REDIS_ADDR=localhost:6379

# --- LLM provider (choose one) ---

# Google / Gemini (default — uses OpenAI-compatible endpoint automatically)
# Get your API key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key

# OpenAI (comment out GOOGLE_API_KEY and set this instead)
# OPENAI_API_KEY=your_openai_api_key

# Any OpenAI-compatible provider (Ollama, Groq, Azure, etc.)
# Set OPENAI_BASE_URL to point at the provider's endpoint.
# OPENAI_API_KEY=your_api_key
# OPENAI_BASE_URL=http://localhost:11434/v1

# --- Model selection (optional) ---
# Defaults: gemini-2.0-flash (Gemini), gpt-4o-mini (OpenAI)
# For Gemini model IDs see: https://ai.google.dev/gemini-api/docs/models
# MODEL=gemini-2.0-flash
# MODEL=gemini-3.1-flash-lite-preview

# --- Optional: example tool integrations ---

# Finnhub API key — enables built-in stock market tools (https://finnhub.io, free tier available)
# Leave unset to run the base agent without these tools.
# See go/cmd/adk-server/finnhub_tools.go (or python/src/memlayer_agent/finnhub_tools.py)
# for the implementation — use it as a template to add your own tools.
# FINNHUB_API_KEY=your_finnhub_api_key

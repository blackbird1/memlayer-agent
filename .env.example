# --- Required ---

# Google / Gemini API key (https://aistudio.google.com/apikey)
GOOGLE_API_KEY=your_google_api_key

# ProcIQ MCP bearer token (https://prociq.ai — sign up, create org, generate token)
MEMLAYER_MCP_BEARER_TOKEN=your_memlayer_mcp_bearer_token

# Redis address (Docker Compose sets this automatically; override for local dev)
REDIS_ADDR=localhost:6379

# --- Model selection (optional) ---
# Defaults to gemini-3.1-flash-preview if not set.
# --- Gemini 3.1 Series (current, 1M context) ---
# Pro (complex reasoning, agentic):     gemini-3.1-pro-preview
# Flash (default production):           gemini-3.1-flash-preview
# Flash-Lite (high-volume, low-cost):   gemini-3.1-flash-lite-preview
# --- Gemini 3 Series ---
# Flash (previous default):             gemini-3-flash-preview
# Deep Think (multi-step reasoning):    gemini-3-deep-think-preview
MODEL=gemini-3.1-flash-preview

# --- Optional: example tool integrations ---

# Finnhub API key — enables built-in stock market tools (https://finnhub.io, free tier available)
# Leave unset to run the base agent without these tools.
# See go/cmd/adk-server/finnhub_tools.go (or python/src/memlayer_agent/finnhub_tools.py)
# for the implementation — use it as a template to add your own tools.
# FINNHUB_API_KEY=your_finnhub_api_key
